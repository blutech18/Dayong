# ─────────────────────────────────────────────────────────────
# DAYONG — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Supabase project (Project Settings → API)
# Public values — safe to expose to the browser (prefixed VITE_).
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only secret — NEVER expose to the browser.
# Used by server functions for privileged operations (admin auth, seeding).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Postgres connection string for Drizzle migrations & server queries.
# Supabase: Project Settings → Database → Connection string (use the
# "Session" pooler for app runtime, "Direct" for migrations).
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres"

# App base URL — used for password-reset / email redirect links.
APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Email (optional) — transactional notifications via Resend.
# If RESEND_API_KEY is unset, emails are logged instead of sent.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="DAYONG <onboarding@resend.dev>"
